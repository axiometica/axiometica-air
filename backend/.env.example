# ============================================================
# AgenticPlatform v2 — Environment Variables
# Copy to .env and fill in real values before starting.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/agentic_os

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Security (REQUIRED in production) ───────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRY_HOURS=8

# Runtime environment — set to "production" to enforce JWT_SECRET
ENVIRONMENT=development

# ── Initial user passwords (used only on first startup seed) ─
ADMIN_INITIAL_PASSWORD=CHANGE_ME
ITOM_ADMIN_INITIAL_PASSWORD=CHANGE_ME
OPERATOR_INITIAL_PASSWORD=CHANGE_ME
VIEWER_INITIAL_PASSWORD=CHANGE_ME

# ── API keys ─────────────────────────────────────────────────
WATCHER_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── CORS (comma-separated list of allowed frontend origins) ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Flower monitoring (basic auth) ───────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME

# ── Neo4j CMDB ───────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ── LLM (optional — enables AI summaries and runbook generation) ──
OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# ── Slack ChatOps (optional) ─────────────────────────────────
# Obtain from https://api.slack.com/apps
# Bot Token Scopes required: chat:write, app_mentions:read, im:read, im:write,
#                            im:history, users:read, users:read.email
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ── ServiceNow integration (optional) ───────────────────────
# SNOW_INSTANCE=https://your-instance.service-now.com
# SNOW_API_USER=api_user
# SNOW_API_PASSWORD=api_password

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
