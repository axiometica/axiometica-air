*.pyc
*.pyo

# Frontend specific
frontend/.turbo/
frontend/.cache/

# Backend specific
backend/.pytest_cache/
backend/.mypy_cache/
backend/.state/

# Redis dump
dump.rdb

# Docker
.docker

# Local Docker Compose overrides (local-only services, never committed)
docker-compose.override.yml

# Archives
*.zip
*.tar.gz

# Temporary files
*.tmp
*.temp
.tmp/
.tmp_*
.tmp_session_extracts/

# Development archive — old dev docs, session logs, planning notes
_dev_archive/

# Local RAG reference folder — AI assistant context docs, not source code
_rag/

# Marketing collateral and business documents — stored locally, not source code
MarketDocs/
RD_TAX_CREDIT_PREP/

# Claude Code local config (editor tooling, not project code)
.claude/
**/.claude/

# UI component backups (timestamped snapshot folders)
BACKUPS_UI_*/

# Runtime backup output — entire backups/ folder excluded from git.
# The backup scripts (scripts/backup.sh, tasks/backup.py) create these
# directories at runtime; they must not be committed.
backups/

# Vite dev cache
frontend/.vite/

# Auto-generated code (scaffolding, migrations, etc.)
*.generated.*
*.scaffold.*

# Local development notes and scratch files (AI-generated or manual)
*.scratch
NOTES.local.md
ANALYSIS.md
INVESTIGATION.md
local-notes/
scratch/

# Generated analysis and reports
*_analysis.md
*_report.md
*_summary.md
analysis_*.txt

# Nginx TLS certificates (auto-generated; never commit private keys)
nginx/certs/

# Old release assets and local reference docs (covered by *.md and *.docx above)
postgresql.conf

# Local-only testing tools (never push)
event_simulator/
backend/tests/unit/
